# OpenClaw Configuration
# Copy to .env and fill in your actual API keys

# OpenRouter API key (recommended for flexibility across multiple model providers)
# Automatically configures OpenClaw on container startup if provided
OPENROUTER_API_KEY=sk-or-...

# Alternative: Anthropic API key
# ANTHROPIC_API_KEY=sk-ant-...

# Alternative: OpenAI API key
# OPENAI_API_KEY=sk-...

# Optional: Setup password for Railway template initialization
# Used for /setup endpoint security
SETUP_PASSWORD=password

# Optional: Override the default model in openclaw.json
# Examples: openai/gpt-4o, openai/gpt-4-turbo, anthropic/claude-opus-4-7
# OPENCLAW_MODEL=anthropic/claude-opus-4-7
